{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RobustnessBoundaryConfig",
  "type": "object",
  "required": ["name", "splits", "perturbations"],
  "properties": {
    "name": {"type": "string"},
    "seed": {"type": "integer"},
    "output_dir": {"type": "string"},
    "include_unperturbed_baseline": {"type": "boolean"},
    "export_language_outputs": {"type": "boolean"},
    "notes": {"type": ["string", "null"]},
    "metadata": {"type": "object"},
    "splits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["split_name", "role", "manifest_path"],
        "properties": {
          "split_name": {"type": "string"},
          "role": {"type": "string"},
          "manifest_path": {"type": "string"},
          "enabled": {"type": "boolean"},
          "allow_missing_manifest": {"type": "boolean"},
          "tags": {
            "type": "array",
            "items": {"type": "string"}
          },
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "perturbations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "severities"],
        "properties": {
          "name": {"type": "string"},
          "enabled": {"type": "boolean"},
          "severities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "number",
              "minimum": 0
            }
          },
          "params": {"type": "object"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

