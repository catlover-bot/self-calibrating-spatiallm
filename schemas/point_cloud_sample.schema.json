{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PointCloudSample",
  "type": "object",
  "required": ["sample_id", "points"],
  "properties": {
    "sample_id": {"type": "string"},
    "sensor_frame": {"type": "string"},
    "metadata": {"type": "object"},
    "points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["x", "y", "z"],
        "properties": {
          "x": {"type": "number"},
          "y": {"type": "number"},
          "z": {"type": "number"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
