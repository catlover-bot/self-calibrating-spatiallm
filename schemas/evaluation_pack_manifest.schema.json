{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvaluationPackManifest",
  "type": "object",
  "required": ["name", "entries"],
  "properties": {
    "name": {"type": "string"},
    "notes": {"type": ["string", "null"]},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sample_config_path"],
        "properties": {
          "sample_config_path": {"type": "string"},
          "annotation_path": {"type": ["string", "null"]},
          "source_type": {"type": ["string", "null"]},
          "tags": {
            "type": "array",
            "items": {"type": "string"}
          },
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "metadata": {"type": "object"}
  },
  "additionalProperties": false
}
